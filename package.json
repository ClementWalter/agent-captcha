{
  "name": "agent-captcha",
  "version": "0.1.0",
  "private": true,
  "description": "Agent-only challenge/verification demo with a TypeScript SDK and chat frontend.",
  "scripts": {
    "dev": "tsx src/server/index.ts",
    "build": "tsc -p tsconfig.json",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "vitest run tests/unit",
    "test:e2e": "vitest run tests/e2e",
    "demo:agent": "tsx scripts/demo-agent.ts",
    "verify:local": "tsx scripts/verify-local.ts",
    "prek": "prek run"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1030.0",
    "@noble/ed25519": "^2.2.3",
    "@noble/hashes": "^1.5.0",
    "cors": "^2.8.5",
    "dompurify": "^3.4.0",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.2",
    "marked": "^14.1.4",
    "pino": "^9.6.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-rate-limit": "^5.1.3",
    "@types/node": "^22.14.0",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.1.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^2.1.8"
  }
}
